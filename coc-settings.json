{
   "explorer.width": 30,
   "explorer.buffer.root.template": "[icon & 1] BUFERS",
   "explorer.file.root.template": "[icon & 1] FILES ([root])",
   "explorer.file.child.template": "[git | 2] [selection | clip | 1] [indent][icon | 1] [diagnosticError & 1][filename omitCenter 1][modified][readonly] [linkIcon & 1][link growRight 1 omitCenter 5]",
   "explorer.file.showHiddenFiles": true,
   "explorer.file.autoReveal": false,
   "explorer.previewAction.onHover": false,

   "tailwindCSS.enable": true,

   "snippets.userSnippetsDirectory": "~/.config/nvim/custom/snippets",

   "prettier.useTabs": false,
   "prettier.singleQuote": true,
   "prettier.jsxBracketSameLine": true,
   "prettier.semi": false,
   "prettier.tabWidth": 3
}
